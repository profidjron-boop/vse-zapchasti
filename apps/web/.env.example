# Server-side API base URL (used by Next.js server components).
# Dev example:
API_BASE_URL=http://localhost:8000
# Prod example (must not be localhost):
# API_BASE_URL=https://api.example-auto.ru

# Client-side API base URL (used in browser fetch calls).
# Dev example:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Prod example (must not be localhost):
# NEXT_PUBLIC_API_BASE_URL=https://api.example-auto.ru

# Public site URL (used for metadataBase, robots and sitemap generation).
# Dev example:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Prod example:
# NEXT_PUBLIC_SITE_URL=https://example-auto.ru
