# API runtime
DATABASE_URL=postgresql+psycopg://vsez:change-me-strong-password@postgres:5432/vsez
WEB_ORIGIN=https://vsezapchasti.ru
JWT_SECRET_KEY=change-me-very-long-random-secret
UPLOAD_DIR=/uploads
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_REDIS_URL=
SQLALCHEMY_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
PUBLIC_FORMS_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_FORMS_RATE_LIMIT_PER_MINUTE=20
PUBLIC_PRODUCTS_SNAPSHOT_CACHE_TTL_SECONDS=300
PUBLIC_CONTENT_CACHE_TTL_SECONDS=15
PUBLIC_CATEGORIES_CACHE_TTL_SECONDS=15

# Optional auth/session hardening
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=lax

# Notifications (fill only if channel is enabled)
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_SMTP_STARTTLS=true
NOTIFY_SMS_WEBHOOK_URL=
NOTIFY_MESSENGER_WEBHOOK_URL=
NOTIFY_WEBHOOK_ALLOWED_HOSTS=
