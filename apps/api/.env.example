# Dev database (docker-compose postgres on host port 5433)
DATABASE_URL=postgresql+psycopg://vsez:vsez_dev_password_change_me@localhost:5433/vsez
WEB_ORIGIN=http://localhost:3000
JWT_SECRET_KEY=change-me-long-random-secret
UPLOAD_DIR=apps/web/public/uploads
REDIS_URL=redis://localhost:6379/0
# Optional explicit override for rate-limit backend (if unset, REDIS_URL is used)
RATE_LIMIT_REDIS_URL=
SQLALCHEMY_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
PUBLIC_FORMS_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_FORMS_RATE_LIMIT_PER_MINUTE=20
PUBLIC_PRODUCTS_SNAPSHOT_CACHE_TTL_SECONDS=300
PUBLIC_CONTENT_CACHE_TTL_SECONDS=15
PUBLIC_CATEGORIES_CACHE_TTL_SECONDS=15
